rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /students/{studentId} {
      allow read, write: if isSignedIn();
    }

    match /charges/{chargeId} {
      allow read, write: if isSignedIn();
    }

    match /payments/{paymentId} {
      allow read, write: if isSignedIn();
    }
  }
}
